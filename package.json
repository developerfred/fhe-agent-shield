{
  "name": "@developerfred/fhe-agent-shield",
  "description": "",
  "version": "1.1.0",
  "author": {
    "name": "developerfred",
    "url": "https://github.com/developerfred"
  },
  "dependencies": {
    "@fhenixprotocol/contracts": "0.3.1",
    "@openzeppelin/contracts": "^5.0.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun": "^1.1.22",
    "forge-std": "github:foundry-rs/forge-std#v1.8.1",
    "prettier": "^3.3.3",
    "solhint": "^3.6.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "forge",
    "foundry",
    "smart-contracts",
    "solidity",
    "template"
  ],
  "private": true,
  "scripts": {
    "clean": "rm -rf cache out",
    "build": "forge build",
    "lint": "bun run lint:sol && bun run prettier:check",
    "lint:sol": "forge fmt --check && bun solhint {script,src,test}/**/*.sol",
    "prettier:check": "prettier --check \"**/*.{json,md,yml}\" --ignore-path \".prettierignore\"",
    "prettier:write": "prettier --write \"**/*.{json,md,yml}\" --ignore-path \".prettierignore\"",
    "test": "forge test",
    "test:coverage": "forge coverage",
    "test:coverage:report": "forge coverage --report lcov && genhtml lcov.info --branch-coverage --output-dir coverage",
    "test:ts": "vitest run",
    "test:ts:watch": "vitest"
  },
  "vitest": {
    "testTimeout": 30000,
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "json",
        "html"
      ],
      "exclude": [
        "node_modules/",
        "lib/",
        "out/",
        "dist/"
      ]
    }
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
